<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="stylesheet" href="/styles.css" />
    <title>Share Link</title>
  </head>

  <body>
    <div class="container">
      <div class="card">
        <h1>Share Link Created</h1>

        <p>Copy this link:</p>

        <input type="text" value="<%= link %>" readonly style="width: 400px" />

        <br /><br />

        <a href="<%= link %>" target="_blank"> Open Link </a>

        <br /><br />

        <a href="/folders"> Back to folders </a>
      </div>
    </div>
  </body>
</html>
