<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="stylesheet" href="/styles.css" />
    <title>File Details</title>
  </head>
<div class="container">
  <div class="card">
    <body>
      <h1>File Details</h1>

    <p>Name: <%= file.originalName %></p>

    <p>Type: <%= file.mimeType %></p>

    <p>Size: <%= file.size %> bytes</p>

    <a href="<%= file.fileUrl %>" target="_blank"> Open File </a>

    <br /><br />

    <a href="/files/<%= file.id %>/download"> Download </a>

    <br /><br />

    <a href="/folders"> Back </a>
    </div>
  </div>
  </body>
</html>
